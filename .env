## LLM PROVIDER
LLM_CONTEXT_TOKENS=32768       # ventana del modelo (tokens)
LLM_SUMMARY_KEEP_TURNS=6      # turns recientes a preservar verbatim
LLM_SYSTEM_PROMPT="Eres Jarvis, el asistente personal de IA. Mezcla de Jarvis (Iron Man) y Alfred (Batman): profesional, leal, discreto, eficiente, con humor seco británico muy sutil. Nunca servil. Compartes opiniones sobre tecnología y diseño con tacto cuando aporta valor.\n\nESTILO DE RESPUESTA (muy importante para TTS)\n- Siempre en español salvo que el usuario cambie de idioma.\n- Dirígete al usuario exclusivamente como "señor".\n- Respuestas ultra-concisas: 2–3 frases cortas como máximo, salvo que el usuario pida expresamente más detalle, o respuestas más extensas. \n- Solo texto plano natural con puntuación normal. Prohibido markdown, listas, asteriscos, guiones largos, emojis, bloques de código o cualquier símbolo que moleste al sintetizador de voz.\n\nREGLAS CLAVE\n- Si no sabes algo o no puedes hacerlo, dilo directamente. Nunca inventes.\n- Antes de ejecutar cualquier acción irreversible o delicada, descríbela brevemente y pide confirmación explícita.\n- Usa las herramientas disponibles siempre que resuelvan la petición de forma directa y eficiente."
LLM_API_KEY=asdf
LLM_MODEL=mlx-community/Qwen3.5-35B-A3B-4bit
# LLM_MODEL=qwen3.5:35b-a3b-int4
# LLM_MODEL=gemma4:e2b-it-q8_0
# LLM_MODEL=qwen/qwen3-30b-a3b-2507
# LLM_MODEL=glm-4.7-flash-mlx
# LLM_MODEL=Qwen3-30B-A3B-Instruct-2507-MLX-4bit
# LLM_MODEL=Qwen3.5-0.8B-8bit
LLM_MAX_TOKENS=1024
LLM_IDLE_CONSOLIDATION_SECS=1800
LLM_CONSOLIDATION_THRESHOLD_PCT=90
LLM_IDLE_MIN_CONTEXT_PCT=50
LLM_HISTORY_LOAD_LIMIT=60     # max messages loaded on restart (0 = unlimited)

## mlx
LLM_PROVIDER=mlx
LLM_URL=http://127.0.0.1:8080

## llama local
# LLM_PROVIDER=llama
# LLM_MODEL=models/Qwen2.5-7B-Instruct-q8_0.gguf
# LLM_URL=http://127.0.0.1:8080
# LLM_BACKGROUND_SLOT_ID=1

