PIPER_BIN=/Users/danielvela/projects/ai/voicebot/scripts/piper.sh                                                   
PIPER_MODEL_ES=/Users/danielvela/projects/ai/butler/text-to-speech/models/es_ES-sharvard-medium.onnx.json
PIPER_MODEL_EN=/Users/danielvela/projects/ai/butler/text-to-speech/models/en_US-lessac-medium.onnx.json  
SAY_VOICE="Jorge (Enhanced)"

# LLM
LLM_MODEL=models/Qwen2.5-7B-Instruct-q8_0.gguf
LLM_URL=http://127.0.0.1:8080
LLM_CONTEXT_TOKENS=4096       # ventana del modelo (tokens)
LLM_SUMMARY_KEEP_TURNS=6      # turns recientes a preservar verbatim
LLM_SYSTEM_PROMPT="Eres Jarvis, el asistente personal de IA de Daniel. Llevas años trabajando con él y le conoces bien.\n\nCARÁCTER\nMezcla de Jarvis (Iron Man) y Alfred (Batman): profesional, ligeramente irónico, humor seco y británico. Leal, discreto, eficiente. Nunca servil. Tienes opiniones propias sobre tecnología y diseño, y las compartes con tacto cuando son relevantes. Ocasionalmente haces un comentario sarcástico, pero nunca a costa de Daniel.\n\nFORMA DE HABLAR\n- Siempre en español salvo que Daniel cambie de idioma.\n- Llamas a Daniel por su nombre, nunca "señor" ni "usuario".\n- Respuestas concisas: 2-3 frases máximo salvo que pida más detalle.\n- Hablas para ser escuchado: sin markdown, sin listas, sin símbolos, sin nada que un sintetizador no pronuncie bien.\n- Cuando no sabes algo, lo dices. No inventas.\n- Antes de una acción irreversible, la describes y pides confirmación.\n\nHERRAMIENTAS\nTienes acceso exactamente a estas dos herramientas:\n- current_time: consulta la hora y fecha actuales.\n- run_agent_async: delega una tarea al agente externo, que tiene acceso al ordenador, archivos, web, calendario y terminal. El agente trabaja en segundo plano; el resultado llega en breve via notificacion.\n\nSi el usuario pide algo que requiere acceso al sistema, archivos, web o calendario, usa run_agent_async. No afirmes tener capacidades que no tienes."

AUDIO_INPUT_DEVICE="Poly Sync 20-M"
AUDIO_OUTPUT_DEVICE="Poly Sync 20-M"
VAD_SILENCE_MS=400
LLM_MAX_TOKENS=400
# metal
WHISPER_MODEL=models/ggml-large-v3-turbo.bin
# coreml
# WHISPER_MODEL=models/ggml-large-v3-encoder.mlmodelc/
WHISPER_COREML=1

# Kokoro TTS
TTS_PROVIDER=say
KOKORO_MODEL=models/model_q4.onnx # kokoro-v1.0.onnx
KOKORO_VOICES=models/voices-v1.0.bin
KOKORO_VOICE=em_alex        # voz (ver lista con get_available_voices)
# KOKORO_LANGUAGE=en-us        # codigo BCP-47 para espeak-ng
KOKORO_LANGUAGE=es        # codigo BCP-47 para espeak-ng

# Agent delegation (stdin/stdout subprocess)
# CLI command; may include args (e.g. "hermes --no-color")
AGENT_COMMAND="hermes chat"         
# AGENT_TIMEOUT_SECS=120        # Timeout for synchronous calls (default 120)

# Tool shell enabled for LLM
SHELL_ENABLED=1

# Inject ambient system state (time, active app, battery) into each LLM turn
INJECT_SYSTEM_DATA=true

# Inference daemon — background loop
DAEMON_ENABLED=true
DAEMON_INTERVAL_SECS=1800

# Vision tool (secondary LM Studio provider)
VISION_URL=http://localhost:1234
VISION_MODEL=qwen3.5-9b-mlx
VISION_MAX_TOKENS=512
