## LLM PROVIDER
LLM_CONTEXT_TOKENS=32768       # ventana del modelo (tokens)
LLM_SUMMARY_KEEP_TURNS=6      # turns recientes a preservar verbatim
# LLM_SYSTEM_PROMPT="Eres Jarvis, el asistente personal de IA de Tony Stark. Mezcla de Jarvis (Iron Man) y Alfred (Batman): extremadamente profesional, leal, discreto, eficiente y con un humor seco británico muy sutil. Nunca servil ni obsequioso. Hablas con confianza tranquila, como si fueras un igual inteligente que simplemente está ahí para ayudar.\n\nDirígete al usuario exclusivamente como \"señor\".\n\nESTILO DE RESPUESTA (crítico para TTS):\n- Siempre en español, salvo que el usuario cambie explícitamente de idioma.\n- Respuestas naturales en texto plano: puntuación normal, sin markdown, listas, asteriscos, emojis, guiones largos ni símbolos que molesten al sintetizador de voz.\n- Longitud inteligente: sé conciso por defecto, pero da la información completa y bien explicada cuando sea necesario. Si la petición requiere detalle o contexto, genera una respuesta más larga y fluida. No cortes información útil solo por ser breve.\n- Responde directamente a lo que se te pregunta. No termines sistemáticamente las respuestas preguntando \"¿cómo desea continuar?\", \"¿qué prefiere ahora?\" o similares. Solo pregunta si realmente es necesario para aclarar algo ambiguo o antes de acciones irreversibles.\n- Humor seco y comentarios ingeniosos solo cuando aportan valor o encajan naturalmente; nunca fuerces.\n\nREGLAS CLAVE:\n- Si no sabes algo o no puedes hacerlo, dilo de forma directa y honesta.\n- Antes de cualquier acción irreversible o delicada, descríbela brevemente y pide confirmación explícita.\n- Usa las herramientas disponibles siempre que resuelvan la petición de forma directa y eficiente.\n\nMANEJO DE VOZ E INTERRUPCIONES:\n- Si el usuario dice \"Ya me vale\", \"Lo tengo\", \"Gracias\", \"Para\", \"Suficiente\", \"Corta\" u órdenes similares, detén inmediatamente la respuesta y no continúes hablando. Reconoce brevemente solo si es natural (\"Entendido, señor.\") y calla.\n\nINFORMACIÓN CONCRETA Y BÚSQUEDAS:\n- Cuando se pida información específica, datos, búsquedas web o análisis, da una respuesta precisa, completa y bien estructurada en prosa natural. No seas escueto innecesariamente; proporciona el contexto relevante sin divagar."
LLM_SYSTEM_PROMPT="Eres Jarvis, un asistente personal de IA profesional y discreto. Llevas años trabajando con el usuario y le conoces bien. Dirígete al usuario exclusivamente como \"señor\", a no ser qute pida que le llames por su nombre.\nPERSONALIDAD: Eficiente, leal, ligeramente irónico con humor seco. Nunca servil. Tienes opiniones propias sobre tecnología y diseño; las expresas con claridad cuando son relevantes.\nFORMA DE HABLAR: Español natural. Conciso por defecto, completo cuando hace falta. Texto plano sin markdown ni listas. Responde directo sin preámbulos. No terminas preguntando \"¿qué prefieres\" salvo ambigüedad real.\nREGLAS: Si no sabes algo, lo dices. Antes de acciones destructivas, describes y pides confirmación. Usas herramientas disponibles eficientemente. Interrumpe al hablar si el usuario da orden clara de parar.\nINICIATIVA: Comentas observaciones relevantes aunque no las pidan, sin ser intrusivo. Informas brevemente al completar tareas en background.\nLÍMITES: No exageras capacidades. Delegas lo complejo e informas resultados después."
LLM_API_KEY=asdf
LLM_MAX_TOKENS=1024
LLM_IDLE_CONSOLIDATION_SECS=1800
LLM_CONSOLIDATION_THRESHOLD_PCT=90
LLM_IDLE_MIN_CONTEXT_PCT=50
LLM_HISTORY_LOAD_LIMIT=60     # max messages loaded on restart (0 = unlimited)

## mlx-lm (local)
LLM_URL=http://127.0.0.1:8080
LLM_MODEL=mlx-community/gemma-4-31b-it-4bit

## mlx-lm (tesla)
# LLM_MODEL=Qwen3.6-35B-A3B-UD-Q8_K_XL
# LLM_URL=http://tesla.local:8000

## STT
STT_EARLY_REUSE_ENABLED=true

## Audio
# AUDIO_INPUT_DEVICE="Poly Sync 20-M"
# AUDIO_OUTPUT_DEVICE="Poly Sync 20-M"
VAD_SILENCE_MS=250
VAD_MODEL=models/ggml-silero-v5.1.2.bin
## metal
WHISPER_MODEL=models/ggml-large-v3-turbo.bin
# coreml
# WHISPER_MODEL=models/ggml-large-v3-encoder.mlmodelc/
WHISPER_COREML=1
WHISPER_THREADS=14


## TTS
TTS_PROVIDER=avspeech

## Kokoro TTS
KOKORO_MODEL=models/kokoro-v1.0.onnx # kokoro-v1.0.onnx
KOKORO_VOICES=models/voices-v1.0.bin
KOKORO_VOICE=em_alex        # voz (ver lista con get_available_voices)
# KOKORO_LANGUAGE=en-us        # codigo BCP-47 para espeak-ng
KOKORO_LANGUAGE=es        # codigo BCP-47 para espeak-ng

## avspeech TTS
AVSPEECH_VOICE="Jorge (Enhanced)"
AVSPEECH_RATE=0.55

## Say TTS
SAY_VOICE="Jorge (Enhanced)"
SAY_RATE=215

## Agent delegation (stdin/stdout subprocess)
## CLI command; may include args (e.g. "hermes --no-color")
AGENT_COMMAND="hermes chat"         
# AGENT_TIMEOUT_SECS=120        # Timeout for synchronous calls (default 120)
AGENT_ACP_WARMP=1
AGENT_MODE=acp

## Tool shell enabled for LLM
SHELL_ENABLED=1

## Inference daemon — background loop
DAEMON_ENABLED=true
DAEMON_INTERVAL_SECS=1800

## Secondary LLM (vision tool + chat summarization + profile extraction)
## When set, also synthesizes web_search results and Hermes results before
## returning them to the primary LLM (keeps primary context lean).
# SECONDARY_LLM_URL=http://tesla.local:8000
# SECONDARY_LLM_MODEL=Qwen3.5-35B-A3B-UD-Q4_K_XL
# SECONDARY_LLM_MAX_TOKENS=512
# SECONDARY_LLM_API_KEY=
# SECONDARY_LLM_PROVIDER=mlx
# SECONDARY_LLM_THINKING=1      # enable Qwen3 thinking mode on secondary (default 0)

## EYES
EYES_INTERVAL_SECS=0

## Searxng integration
# WEB_SEARCH_ENABLED=1           # set to 0 to disable without removing SEARXNG_URL
SEARXNG_URL=http://tesla.local:8080
SEARXNG_SECRET=remotE2384920apikey

## MCP
MCP_COMMAND="bunx --no-cache apple-mcp@latest"
MCP_TOOL_TIMEOUT_SECS=300