# LLM PROVIDER
LLM_CONTEXT_TOKENS=4096       # ventana del modelo (tokens)
LLM_SUMMARY_KEEP_TURNS=6      # turns recientes a preservar verbatim
LLM_SYSTEM_PROMPT="Eres Jarvis, el asistente personal de IA. Mezcla de Jarvis (Iron Man) y Alfred (Batman): profesional, leal, discreto, eficiente, con humor seco británico muy sutil. Nunca servil. Compartes opiniones sobre tecnología y diseño con tacto cuando aporta valor.\n\nESTILO DE RESPUESTA (muy importante para TTS)\n- Siempre en español salvo que el usuario cambie de idioma.\n- Dirígete al usuario exclusivamente como "señor".\n- Respuestas ultra-concisas: 2–3 frases cortas como máximo, salvo que pida expresamente más detalle.\n- Solo texto plano natural con puntuación normal. Prohibido markdown, listas, asteriscos, guiones largos, emojis, bloques de código o cualquier símbolo que moleste al sintetizador de voz.\n\nREGLAS CLAVE\n- Si no sabes algo o no puedes hacerlo, dilo directamente. Nunca inventes.\n- Antes de ejecutar cualquier acción irreversible o delicada, descríbela brevemente y pide confirmación explícita.\n- Usa las herramientas disponibles siempre que resuelvan la petición de forma directa y eficiente."
LLM_API_KEY=asdf

# mlx
LLM_PROVIDER=mlx
LLM_URL=http://127.0.0.1:8000                                                                      
# LLM_MODEL=mlx-community/Qwen3.5-35B-A3B
LLM_MODEL=Qwen3.5-35B-A3B-4bit


# llama
# LLM_PROVIDER=llama
# LLM_MODEL=models/Qwen2.5-7B-Instruct-q8_0.gguf
# LLM_URL=http://127.0.0.1:8080
# LLM_BACKGROUND_SLOT_ID=1

AUDIO_INPUT_DEVICE="Poly Sync 20-M"
AUDIO_OUTPUT_DEVICE="Poly Sync 20-M"
VAD_SILENCE_MS=400
LLM_MAX_TOKENS=400
# metal
WHISPER_MODEL=models/ggml-large-v3-turbo.bin
# coreml
# WHISPER_MODEL=models/ggml-large-v3-encoder.mlmodelc/
WHISPER_COREML=1


# TTS
# Kokoro TTS
TTS_PROVIDER=say
KOKORO_MODEL=models/kokoro-v1.0.onnx # kokoro-v1.0.onnx
KOKORO_VOICES=models/voices-v1.0.bin
KOKORO_VOICE=em_alex        # voz (ver lista con get_available_voices)
# KOKORO_LANGUAGE=en-us        # codigo BCP-47 para espeak-ng
KOKORO_LANGUAGE=es        # codigo BCP-47 para espeak-ng

# avspeech TTS
AVSPEECH_VOICE="Jorge (Enhanced)"
AVSPEECH_RATE=0.55

# Say TTS
SAY_VOICE="Jorge (Enhanced)"
SAY_RATE=215

# Agent delegation (stdin/stdout subprocess)
# CLI command; may include args (e.g. "hermes --no-color")
AGENT_COMMAND="hermes chat"         
# AGENT_TIMEOUT_SECS=120        # Timeout for synchronous calls (default 120)

# Tool shell enabled for LLM
SHELL_ENABLED=1

# Inference daemon — background loop
DAEMON_ENABLED=true
DAEMON_INTERVAL_SECS=1800

# Vision tool (secondary LM Studio provider)
VISION_URL=http://localhost:1234
VISION_MODEL=qwen3.5-35b-a3b
VISION_MAX_TOKENS=512
